{
  "functions": {
    "api/concurrents.js": { "maxDuration": 60 },
    "api/sentinelle.js": { "maxDuration": 60 }
  },
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, max-age=0, must-revalidate" }
      ]
    }
  ]
}
